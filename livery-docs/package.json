{
  "name": "livery-docs",
  "version": "0.0.5",
  "private": true,
  "scripts": {
    "bootstrap:livery": "node scripts/bootstrap-livery.mjs",
    "docs:generate": "bun run bootstrap:livery && node scripts/generate-reference.mjs",
    "docs:check": "bun run bootstrap:livery && node scripts/generate-reference.mjs --check && node scripts/check-docs.mjs",
    "build": "bun run docs:generate && next build --webpack",
    "dev": "bun run bootstrap:livery && next dev --webpack",
    "start": "next start",
    "types:check": "bun run docs:generate && fumadocs-mdx && next typegen && tsc --noEmit",
    "postinstall": "fumadocs-mdx",
    "lint": "eslint"
  },
  "dependencies": {
    "@ai-sdk/openai": "^4.0.15",
    "@ai-sdk/react": "^4.0.32",
    "@codemirror/commands": "^6.10.4",
    "@codemirror/language": "^6.12.4",
    "@codemirror/lint": "^6.9.7",
    "@codemirror/search": "^6.7.1",
    "@codemirror/state": "^6.7.1",
    "@codemirror/view": "^6.43.6",
    "@jerkeyray/core": "file:.vendor/packages/core",
    "@jerkeyray/react": "file:.vendor/packages/react",
    "@jerkeyray/web": "file:.vendor/packages/web",
    "@lezer/highlight": "^1.2.3",
    "ai": "^7.0.29",
    "cnfast": "^0.0.8",
    "codemirror": "^6.0.2",
    "fumadocs-core": "16.11.4",
    "fumadocs-mdx": "15.1.1",
    "fumadocs-ui": "npm:@fumadocs/base-ui@16.11.4",
    "lucide-react": "^1.24.0",
    "next": "16.2.10",
    "react": "^19.2.7",
    "react-dom": "^19.2.7",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@tailwindcss/postcss": "^4.3.2",
    "@types/mdx": "^2.0.14",
    "@types/node": "^26.1.1",
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.3",
    "postcss": "^8.5.17",
    "tailwindcss": "^4.3.2",
    "typescript": "^6.0.3",
    "eslint": "^9.39.4",
    "eslint-config-next": "16.2.10"
  },
  "overrides": {
    "@jerkeyray/core": "file:.vendor/packages/core",
    "@jerkeyray/react": "file:.vendor/packages/react",
    "@jerkeyray/web": "file:.vendor/packages/web"
  }
}
